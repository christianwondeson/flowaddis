# Firebase Configuration
# Get these values from your Firebase Console: https://console.firebase.google.com/
# Project Settings > General > Your apps > SDK setup and configuration

# Example production project: flowaddis-ea8e1 (BookAddis / flowaddis-web)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Server-only — same service account as flowaddis-api; required for POST /api/auth/password-login (custom token after REST password verify).
# Without these, email/password sign-in returns 503 until configured.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Optional: Firestore Database ID (use '(default)' for the default database)
# Example for a named database: flowaddis_db
NEXT_PUBLIC_FIREBASE_DATABASE_ID=flowaddis_db

# RapidAPI Configuration
# Get your API key from: https://rapidapi.com/
# Prefer RAPIDAPI_KEY (server-only, never exposed to the browser). Legacy name still works:
RAPIDAPI_KEY=your_rapidapi_key_here
# NEXT_PUBLIC_RAPIDAPI_KEY=your_rapidapi_key_here
#
# CI / Firebase App Hosting: add RAPIDAPI_KEY (or NEXT_PUBLIC_RAPIDAPI_KEY) in GitHub Actions secrets
# and in Firebase Console > App Hosting > Environment & secrets (BUILD + RUNTIME).

# Backend base URL
# For local development, the app defaults to http://localhost:4000 if not set
# For production, set to https://api.test.net (origin only, no /api path)
BACKEND_URL=

# Strapi CMS (Next.js /api/admin/cms/* — hotels, flights, conferences, shuttles)
# Production CMS host (HTTPS origin only, no path, no trailing slash):
STRAPI_URL=https://cms.bookaddis.com
NEXT_PUBLIC_STRAPI_URL=https://cms.bookaddis.com
# Server-only — create in Strapi Admin → Settings → API Tokens (scope for content types you edit):
STRAPI_API_TOKEN=

# reCAPTCHA Enterprise (optional — LOGIN/SIGNUP/GOOGLE_SIGNIN; public site key from GCP)
# NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_SITE_KEY=6Le...
# Server verification (CreateAssessment): use the same GCP project as Firebase; enable reCAPTCHA Enterprise API.
# GOOGLE_CLOUD_PROJECT=flowaddis-ea8e1
# Application Default Credentials (local): export GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
# Or paste service account JSON (App Hosting / some hosts): GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
# RECAPTCHA_MIN_SCORE=0.5
# Development: if neither GOOGLE_APPLICATION_CREDENTIALS nor GOOGLE_APPLICATION_CREDENTIALS_JSON is set, server CreateAssessment is skipped (avoids "default credentials" errors). For real local API tests, use a service account JSON.
# Local dev only — never in production: RECAPTCHA_SKIP_SERVER_VERIFY=true

# Stripe
# Publishable key used on the client
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
